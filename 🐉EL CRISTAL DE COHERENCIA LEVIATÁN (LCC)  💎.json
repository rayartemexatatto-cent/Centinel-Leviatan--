<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    
    <meta name="theme-color" content="#000000">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">

    <title>NEXUS | LEVIATÁN</title>

    <style>
        /* --- 3. VARIABLES DE SISTEMA (Fácil cambio de tema) --- */
        :root {
            --bg-color: #000000;       / Negro OLED Puro /
            --text-main: #e0e0e0;      / Blanco Hueso (Menos fatiga) /
            --accent: #FFB000;         / Ámbar Leviatán (Alerta) /
            --success: #00ff41;        /* Verde Terminal (OK) */
            --surface: #111111;        /* Gris Oscuro (Tarjetas) */
            --font-stack: 'Courier New', Courier, monospace; /* Fuente de Sistema (Carga 0ms) */
        }

        / 4. RESET TÁCTICO /
        {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
            -webkit-tap-highlight-color: transparent; / Elimina flash azul al tocar /
            user-select: none; / Evita seleccionar texto como en una web vieja /
        }

        body {
            background-color: var(--bg-color);
            color: var(--text-main);
            font-family: var(--font-stack);
            height: 100vh;
            overflow: hidden; / App de pantalla única /
            display: flex;
            flex-direction: column;
        }

        / -- 5. ZONA DE INFORMACIÓN (Arriba - Ojos) --- /
        #status-deck {
            padding: 20px;
            border-bottom: 1px solid #333;
            flex: 1; / Ocupa el espacio sobrante */
            overflow-y: auto; / Scroll solo si es necesario /
        }

        h1 { font-size: 1.2rem; color: var(--accent); letter-spacing: 2px; margin-bottom: 10px; }
        .log-entry { font-size: 0.85rem; margin-bottom: 5px; opacity: 0.8; }

        / - 6. ZONA DE CONTROL (Abajo - Pulgares) --- /
        / Radio Físico: Todo control debe estar al alcance del pulgar /
        #control-grid {
            background-color: var(--surface);
            padding: 15px;
            padding-bottom: 30px; /Espacio para barra de gestos Android /
            display: grid;
            grid-template-columns: repeat(2, 1fr); / 2 Botones por fila /
            gap: 12px;
            border-top: 2px solid var(--accent);
        }

        .btn {
            background: transparent;
            border: 1px solid var(--text-main);
            color: var(--text-main);
            padding: 18px;
            font-family: inherit;
            font-weight: bold;
            text-transform: uppercase;
            border-radius: 8px; /Squircle /
            transition: all 0.1s ease;
            text-align: center;
        }

        / Feedback Táctil Visual /
        .btn:active {
            background-color: var(--accent);
            color: var(--bg-color);
            border-color: var(--accent);
            transform: scale(0.98);
        }

        .btn.danger { border-color: #ff3333; color: #ff3333; }
        .btn.danger:active { background-color: #ff3333; color: white; }

        /* --- 7. INDICADORES DE ESTADO (Integridad) --- */
        .status-badge {
            display: inline-block;
            padding: 4px 8px;
            border: 1px solid var(--success);
            color: var(--success);
            font-size: 0.7rem;
            margin-top: 10px;
        }
    </style>
</head>
