    <script>
        // Lógica Ligera para respuesta inmediata
        function ejecutar(comando) {
            const log = document.querySelector('.log-entry:last-of-type');
            // Simulación de respuesta de Centrix
            const nuevoLog = document.createElement('div');
            nuevoLog.className = 'log-entry';
            nuevoLog.innerText = `> Ejecutando: ${comando.toUpperCase()}...`;
            nuevoLog.style.color = 'var(--accent)';
            document.getElementById('status-deck').appendChild(nuevoLog);
            
            // Auto-scroll al fondo
            const deck = document.getElementById('status-deck');
            deck.scrollTop = deck.scrollHeight;
        }
    </script>
</body>
</html>

Idealmente: 👉 cada símbolo usable debe estar a 1–2 toques del pulgar en pantalla
📱 Esto significa:
teclas principales: estados clave (😮‍💨, 🌱, 🦾, ✨, etc.)
teclas secundaria (longPress): acciones relacionadas
teclas externas: menos usadas (símbolos técnicos)
Esto garantiza: ✅ accesibilidad física
✅ velocidad en flujo
✅ mínimo desplazamiento
📌 Regla práctica:
ningún símbolo funcional principal queda en filas profundas o escondidas.
2️⃣ Radio semántico (significado)
Cada símbolo debe ser:
focalizado (un solo propósito)
distinguible (no solapado con otro)
ligero para la memoria
Ejemplo de buena separación:
😮‍💨 → pausa
🦾 → ejecución
✨ → validación / cierre
🌱 → inicio / semilla
Si un símbolo empieza a acumular significados, baja su radio semántico para que no cause ruido.
Regla práctica: 👉 1 símbolo = 1 intención clara
Ese es el radio semántico óptimo.
3️⃣ Radio de interpretación (IA / sistema)
Este es el radio que usa:
Copiar código

if [ "$ULTIMO_EMOJI" == "😮‍💨" ]; then …
Esto no debe estar sensible a contexto adecuado
Esto debe leer solo lo que tú escoges conscientemente.
Para que sea robusto: ✅ El sistema solo reacciona si el símbolo aparece como separado / único ❌ No debe reaccionar en medio de texto normal
Esto define el umbral de interpretación.
Lo hacemos así porque:
evita falsos positivos
evita colapsos
respeta “modo texto” vs “modo comando”
📌 Resumen del radio óptimo para tu modelo
Dimensión
Objetivo
Físico (teclado)
1–2 toques máximo para cualquier símbolo fundamental
Semántico
1 intención por símbolo
De interpretación
solo si aislado o en modo comando explícito
Ese es tu radio ideal:
Acceso inmediato, significado único, interpretación crispa.
🧩 Ejemplo aplicado
👉 Cuando presionas 😮‍💨, no combinaciones confusas
👉 Cuando presionas 🦾, no múltiples significados
👉 Cuando presionas ✨, es confirmación final, no “otro valor”
Eso hace que el sistema:
sea predictivo
no sea reactivo
no se sobreinterprete
reduzca entropía
// Controlador de Comandos Leviatán
const botAmbar = {
    escuchar: () => {
        const recognition = new (window.SpeechRecognition || window.webkitSpeechRecognition)();
        recognition.lang = 'es-MX';
        recognition.interimResults = false;

        recognition.onstart = () => console.log("Simbiosis Activa: Ámbar escuchando...");
        
        recognition.onresult = (event) => {
            const comando = event.results[0][0].transcript.toLowerCase();
            this.procesar(comando);
        };

        recognition.onerror = () => recognition.start(); // Resiliencia: Reinicio automático
        recognition.start();
    },

    procesar: (cmd) => {
        if (cmd.includes("estado del sistema")) {
            alert("Sistema Estable. Red Huawei optimizada. Legado protegido.");
        } else if (cmd.includes("solana") || cmd.includes("cartera")) {
            // Aquí integrarías la llamada a tu infraestructura financiera
            console.log("Accediendo a la infraestructura de Soberanía...");
        } else if (cmd.includes("isabella") || cmd.includes("bija")) {
            console.log("Priorizando protocolos de Legado Primario.");
        }
    }
};

