#!/data/data/com.termux/files/usr/bin/python3
"""
🔧 REPARADOR DE PUENTES LEVIATÁN
Usa APIs gratuitas sin key
"""
import requests
import json
import sys

def analizar_con_deepseek(codigo):
    """Usar DeepSeek API gratuita"""
    try:
        url = "https://api.deepseek.com/chat/completions"
        headers = {"Content-Type": "application/json"}
        
        prompt = f"""Revisa este código Python y ayuda a mejorarlo:
        
{codigo}

Responde en español con:
1. Problemas encontrados
2. Código mejorado
3. Explicación breve"""

        data = {
            "model": "deepseek-chat",
            "messages": [{"role": "user", "content": prompt}],
            "stream": False
        }
        
        response = requests.post(url, json=data, headers=headers, timeout=30)
        if response.status_code == 200:
            return response.json()["choices"][0]["message"]["content"]
        else:
            return f"Error API: {response.status_code}"
    except Exception as e:
        return f"Error conexión: {e}"

def main():
    if len(sys.argv) < 2:
        print("📁 Uso: python reparar_puentes.py archivo.py")
        sys.exit(1)
    
    archivo = sys.argv[1]
    try:
        with open(archivo, 'r', encoding='utf-8') as f:
            codigo = f.read()
    except:
        print(f"❌ No se pudo leer: {archivo}")
        sys.exit(1)
    
    print("🔍 Analizando código...")
    resultado = analizar_con_deepseek(codigo)
    
    print("\n" + "="*60)
    print("📝 RESULTADO DEL ANÁLISIS:")
    print("="*60)
    print(resultado)
    print("="*60)

if __name__ == "__main__":
    main()
END

